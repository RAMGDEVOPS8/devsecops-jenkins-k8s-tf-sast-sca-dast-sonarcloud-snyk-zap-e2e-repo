pipeline {
  agent any
  tools { 
        maven 'Maven_3_5_2'  
    }
   stages{
    stage('CompileandRunSonarAnalysis') {
            steps {
               dir('devsecops-jenkins-k8s-tf-sast-sca-sonarcloud-snyk-repo'){
		sh 'mvn clean verify sonar:sonar -Dsonar.projectKey=asgbuggywebapp -Dsonar.organization=asgbuggywebapp -Dsonar.host.url=https://sonarcloud.io -Dsonar.token=932558e169d66a8f1d1adf470b908a46156f5844'
			}
    }}

	stage('RunSCAAnalysisUsingSnyk') {
            steps {		
                dir('devsecops-jenkins-k8s-tf-sast-sca-sonarcloud-snyk-repo'){
				withCredentials([string(credentialsId: 'SNYK_TOKEN', variable: 'SNYK_TOKEN')]) {
					sh 'mvn snyk:test -fn'
				}
			}
    }}

	stage('Build') { 
            steps { 
            dir('devsecops-jenkins-k8s-tf-sast-sca-sonarcloud-snyk-repo'){
               withDockerRegistry([credentialsId: "dockerlogin", url: ""]) {
                 script{
                 app =  docker.build("asg")
                 }
               }
            }}
    }

	stage('Push') {
            steps {
                 dir('devsecops-jenkins-k8s-tf-sast-sca-sonarcloud-snyk-repo'){

                script{
                    docker.withRegistry('AWS ECR URL', 'ecr:us-west-2:aws-credentials') {
                    app.push("latest")
                    }
                }
            }}
    	}
	  
    stage('Kubernetes Deployment of ASG Bugg Web Application') {
	   steps {
	      withKubeConfig([credentialsId: 'kubelogin']) {
		  sh('kubectl delete all --all -n devsecops')
		  sh ('kubectl apply -f deployment.yaml --namespace=devsecops')
		}
	      }
   	} 
  }
}
